{
  "info": {
    "name": "OpsFlow API",
    "description": "API collection for the OpsFlow Smart Operations System.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Get Workspaces",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/workspaces",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces"]
            }
          }
        },
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "multipart/form-data"}
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "workspace_name", "value": "New Engineering Team", "type": "text"},
                {"key": "workspace_icon", "value": "briefcase", "type": "text"}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/workspaces",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces"]
            }
          }
        },
        {
          "name": "Delete Workspace",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/workspaces/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces", ":id"],
              "variable": [{"key": "id", "value": "workspace-uuid-here"}]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement Search\",\n  \"description\": \"Add global search functionality\",\n  \"priority\": \"high\",\n  \"workspace_id\": \"uuid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"field\": \"status\",\n  \"value\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", ":id"],
              "variable": [{"key": "id", "value": "task-uuid"}]
            }
          }
        }
      ]
    },
    {
      "name": "Team & Invites",
      "item": [
        {
          "name": "Generate Invite",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"uuid\",\n  \"role\": \"member\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/invites",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invites"]
            }
          }
        },
        {
          "name": "Update Member Role",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"manager\",\n  \"workspaceId\": \"uuid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", ":id"],
              "variable": [{"key": "id", "value": "user-uuid"}]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ]
}
